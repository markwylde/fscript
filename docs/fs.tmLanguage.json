{
  "name": "fscript",
  "scopeName": "source.fs",
  "aliases": ["spec", "fscript-spec"],
  "fileTypes": ["fs"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#imports" },
    { "include": "#typeDeclarations" },
    { "include": "#functionDeclarations" },
    { "include": "#arrowFunctions" },
    { "include": "#typeAnnotations" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#constants" },
    { "include": "#properties" },
    { "include": "#functionCalls" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ts",
          "match": "//.*$"
        },
        {
          "name": "comment.block.ts",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.ts",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.ts",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.double.ts",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ts",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.ts",
          "match": "\\b(?:0[xX][0-9a-fA-F]+|\\d(?:_?\\d)*(?:\\.\\d(?:_?\\d)*)?(?:[eE][+-]?\\d(?:_?\\d)*)?)\\b"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "keyword.control.import.ts",
          "match": "\\bimport\\b"
        },
        {
          "name": "keyword.control.from.ts",
          "match": "\\bfrom\\b"
        },
        {
          "name": "keyword.control.export.ts",
          "match": "\\bexport\\b"
        }
      ]
    },
    "typeDeclarations": {
      "patterns": [
        {
          "name": "meta.type.alias.fs",
          "begin": "\\b(type)\\b\\s+([A-Z][A-Za-z0-9_]*)",
          "beginCaptures": {
            "1": { "name": "storage.type.type.ts" },
            "2": { "name": "entity.name.type.type.ts" }
          },
          "end": "(?=$)",
          "patterns": [
            {
              "name": "entity.name.type.parameter.ts",
              "match": "(?<=<)\\s*[A-Z][A-Za-z0-9_]*\\s*(?=,|>)"
            },
            { "include": "#typeAnnotations" },
            { "include": "#builtins" },
            { "include": "#constants" },
            { "include": "#operators" },
            { "include": "#punctuation" }
          ]
        }
      ]
    },
    "functionDeclarations": {
      "patterns": [
        {
          "name": "meta.function.definition.fs",
          "match": "\\b([a-z][a-zA-Z0-9_]*)\\b(?=\\s*=\\s*(?:\\*\\s*)?\\()",
          "captures": {
            "1": { "name": "entity.name.function.ts" }
          }
        }
      ]
    },
    "arrowFunctions": {
      "patterns": [
        {
          "name": "meta.function.parameters.fs",
          "begin": "(\\()",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.parameters.begin.ts" }
          },
          "end": "(\\))(\\s*:\\s*[^=]+)?(\\s*=>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.parameters.end.ts" },
            "2": { "name": "meta.return-type.fs" },
            "3": { "name": "storage.type.function.arrow.ts" }
          },
          "patterns": [
            {
              "name": "variable.parameter.ts",
              "match": "\\b[a-z][a-zA-Z0-9_]*\\b(?=\\s*(?::|,|\\)))"
            },
            { "include": "#typeAnnotations" },
            { "include": "#punctuation" },
            { "include": "#operators" }
          ]
        },
        {
          "name": "storage.type.function.arrow.ts",
          "match": "=>"
        }
      ]
    },
    "typeAnnotations": {
      "patterns": [
        {
          "name": "meta.type.annotation.fs",
          "begin": "(:)(?!:)",
          "beginCaptures": {
            "1": { "name": "punctuation.separator.type.ts" }
          },
          "end": "(?=[=,){}\\]\\n]|=>)",
          "patterns": [
            {
              "name": "entity.name.type.type.ts",
              "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
            },
            {
              "name": "entity.name.type.parameter.ts",
              "match": "\\b[a-zA-Z][A-Za-z0-9_]*\\b(?=\\s*(?:,|>|\\[\\]|\\||&|$))"
            },
            { "include": "#constants" },
            { "include": "#operators" },
            { "include": "#punctuation" }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.ts",
          "match": "\\b(if|else|match|try|catch|throw)\\b"
        },
        {
          "name": "keyword.control.flow.ts",
          "match": "\\b(yield|defer)\\b"
        },
        {
          "name": "keyword.operator.expression.typeof.ts",
          "match": "\\bas\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.type.primitive.ts",
          "match": "\\b(Number|String|Boolean|Null|Undefined|Never|Unknown|Void)\\b"
        },
        {
          "name": "entity.name.type.type.ts",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.ts",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.ts",
          "match": "\\b(Null|Undefined|null|undefined)\\b"
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "name": "variable.other.property.ts",
          "match": "\\b[a-z][a-zA-Z0-9_]*\\b(?=\\s*:)"
        }
      ]
    },
    "functionCalls": {
      "patterns": [
        {
          "name": "support.function.ts",
          "match": "\\b[a-z][a-zA-Z0-9_]*\\b(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.ts",
          "match": "="
        },
        {
          "name": "keyword.operator.arrow.ts",
          "match": "=>"
        },
        {
          "name": "keyword.operator.pipeline.fs",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.spread.ts",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.comparison.ts",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.ts",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.ts",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.type.annotation.ts",
          "match": "\\||&"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.ts",
          "match": ","
        },
        {
          "name": "punctuation.terminator.statement.ts",
          "match": ";"
        },
        {
          "name": "punctuation.accessor.ts",
          "match": "\\."
        },
        {
          "name": "meta.brace.round.ts",
          "match": "[()]"
        },
        {
          "name": "meta.brace.square.ts",
          "match": "[\\[\\]]"
        },
        {
          "name": "meta.brace.curly.ts",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.generic.begin.ts",
          "match": "<"
        },
        {
          "name": "punctuation.definition.generic.end.ts",
          "match": ">"
        }
      ]
    }
  }
}
