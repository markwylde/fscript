---
interface Props {
  initialCode: string;
}

const { initialCode } = Astro.props;
// Extreme trim to ensure no blank lines at start
const trimmedCode = initialCode?.replace(/^\s+|\s+$/g, '');
---

<div class="sandbox-shell not-content" data-fscript-sandbox>
  <!-- Pass the initial code via a script tag to preserve exact characters -->
  <script type="text/plain" data-role="initial-code" set:html={trimmedCode}></script>
  
  <div class="sandbox-toolbar">
    <div class="sandbox-status-area">
      <span class="sandbox-status" data-role="status">Loading compiler...</span>
    </div>
    <div class="sandbox-actions">
      <button type="button" class="sandbox-btn sandbox-btn-primary" data-role="run">Run</button>
      <button type="button" class="sandbox-btn" data-role="share">Share</button>
    </div>
  </div>

  <div class="sandbox-panels">
    <section class="sandbox-editor-panel">
      <div class="sandbox-editor" data-role="editor"></div>
    </section>

    <section class="sandbox-output-panel">
      <pre class="sandbox-output" data-role="output">Compiler is loading...</pre>
    </section>
  </div>
</div>

<script>
  import { mountSandboxes } from './Sandbox';
  mountSandboxes();
</script>

<style is:global>
  /* 
    IDE MODE: NUCLEAR STRIKE 
    We use fixed positioning to completely take over the viewport below the nav.
    This bypasses any Starlight layout issues, titles, or padding.
  */
  
  [data-template="splash"] .main-frame {
    overflow: hidden !important;
    height: 100vh !important;
  }

  /* Hide EVERYTHING except the nav and our sandbox */
  [data-template="splash"] .content-panel,
  [data-template="splash"] footer,
  [data-template="splash"] h1,
  [data-template="splash"] .sl-breadcrumbs {
    display: none !important;
  }

</style>

<style>
  .sandbox-shell {
    position: fixed;
    top: var(--sl-nav-height);
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    background: #020617;
    z-index: 10; /* Above Starlight's content but below nav */
  }

  .sandbox-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.15);
    background: #0f172a;
    flex-shrink: 0;
  }

  .sandbox-status {
    color: #64748b;
    font-size: 0.8rem;
    font-family: var(--sl-font-mono);
  }

  .sandbox-actions {
    display: flex;
    gap: 0.5rem;
  }

  .sandbox-btn {
    appearance: none;
    border: 1px solid rgba(148, 163, 184, 0.3);
    background: #1e293b;
    color: #f8fafc;
    border-radius: 4px;
    padding: 0.3rem 0.75rem;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
  }

  .sandbox-btn-primary {
    background: #10b981;
    border-color: #059669;
    color: #064e3b;
  }

  .sandbox-panels {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    flex: 1;
    min-height: 0;
  }

  .sandbox-editor-panel {
    border-right: 1px solid rgba(148, 163, 184, 0.15);
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  .sandbox-output-panel {
    min-height: 0;
    display: flex;
    flex-direction: column;
    background: #020617;
  }

  .sandbox-editor {
    flex: 1;
    min-height: 0;
  }

  .sandbox-output {
    flex: 1;
    margin: 0;
    padding: 1.5rem;
    overflow: auto;
    color: #e2e8f0;
    font-size: 0.95rem;
    line-height: 1.6;
    font-family: "JetBrains Mono", "Fira Code", monospace;
  }

  @media (max-width: 1000px) {
    .sandbox-panels {
      grid-template-columns: 1fr;
      grid-template-rows: 1.5fr 1fr;
    }
  }
</style>
